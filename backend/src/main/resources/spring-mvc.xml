<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd http://www.springframework.org/schema/mvc http://www.springframework.org/schema/mvc/spring-mvc.xsd">
    <context:component-scan base-package="com.useditemmarket.controller"/>
    <context:component-scan base-package="com.useditemmarket.exception"/>

    <mvc:annotation-driven/>
    <bean class="com.useditemmarket.config.ImageResourceConfig"/>

    <bean id="multipartResolver" class="org.springframework.web.multipart.commons.CommonsMultipartResolver">
        <property name="maxUploadSize" value="5242880"/>
        <property name="defaultEncoding" value="UTF-8"/>
    </bean>

    <mvc:cors>
        <mvc:mapping path="/api/**"
                     allowed-origins="*"
                     allowed-methods="GET,POST,PUT,DELETE,OPTIONS"
                     allowed-headers="*"/>
    </mvc:cors>

    <mvc:interceptors>
        <mvc:interceptor>
            <mvc:mapping path="/api/**"/>
            <mvc:exclude-mapping path="/api/auth/login"/>
            <mvc:exclude-mapping path="/api/auth/register"/>
            <mvc:exclude-mapping path="/api/catalog/goods"/>
            <mvc:exclude-mapping path="/api/catalog/goods/*"/>
            <mvc:exclude-mapping path="/api/catalog/categories"/>
            <mvc:exclude-mapping path="/api/wanted/open"/>
            <ref bean="authInterceptor"/>
        </mvc:interceptor>
    </mvc:interceptors>

</beans>
